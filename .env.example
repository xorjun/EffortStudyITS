# Appwrite project metadata used by the Angular client and local tooling.
APPWRITE_PROJECT_ID=your-appwrite-project-id
APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
APPWRITE_DATABASE_ID=study_db
APPWRITE_DOWNLOAD_BUCKET_ID=download_zips
APPWRITE_ADMIN_TEAM_ID=admins
APPWRITE_FUNCTION_AUTH_INIT_ID=auth-init
APPWRITE_FUNCTION_SESSION_START_ID=session-start
APPWRITE_FUNCTION_SESSION_COMPLETE_ID=session-complete
APPWRITE_FUNCTION_GENERATE_SURVEY_URL_ID=generate-survey-url
APPWRITE_FUNCTION_AI_PROXY_ID=ai-proxy
APPWRITE_FUNCTION_CHECK_BANNERS_ID=check-banners
APPWRITE_FUNCTION_SUBMIT_BANNER_RESPONSE_ID=submit-banner-response
APPWRITE_FUNCTION_LIST_BANNERS_ID=list-banners
APPWRITE_FUNCTION_SAVE_BANNER_ID=save-banner
APPWRITE_FUNCTION_DELETE_BANNER_ID=delete-banner
APPWRITE_FUNCTION_EXPORT_PARTICIPANTS_ID=export-participants
APPWRITE_FUNCTION_EXPORT_BANNER_RESPONSES_ID=export-banner-responses
ITS_BASE_URL=http://localhost:8080

# Appwrite Function server SDK credentials.
APPWRITE_API_KEY=replace-with-function-api-key

# SoSci redirect and HMAC settings used by survey functions.
SURVEY_LINK_SECRET=replace-with-hmac-secret
SOSCI_BASE_URL=https://www.soscisurvey.de/your-survey

# LLM proxy configuration used by ai-proxy.
LLM_API_KEY=replace-with-llm-api-key
LLM_MODEL=replace-with-llm-model-name

# Prolific completion codes used by survey-return.
PROLIFIC_COMPLETION_CODE_DAY1_A=replace-with-day1-condition-a-code
PROLIFIC_COMPLETION_CODE_DAY1_B=replace-with-day1-condition-b-code
PROLIFIC_COMPLETION_CODE_FINAL=replace-with-final-completion-code
