{
  "name": "its-ui",
  "version": "0.0.0",
  "scripts": {
    "generate:runtime-config": "node ./scripts/write-runtime-config.mjs",
    "ng": "ng",
    "start": "npm run generate:runtime-config && ng serve --configuration staging --host 0.0.0.0 --poll 500 --live-reload-port 42001",
    "build": "npm run generate:runtime-config && ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "dev": "lite-server --baseDir='dist/its_ui'"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^19.2.19",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.19",
    "@angular/compiler": "^19.2.19",
    "@angular/core": "^19.2.19",
    "@angular/forms": "^19.2.19",
    "@angular/material": "^19.2.19",
    "@angular/platform-browser": "^19.2.19",
    "@angular/platform-browser-dynamic": "^19.2.19",
    "@angular/router": "^19.2.19",
    "appwrite": "^17.0.0",
    "angular-split": "^19.0.0",
    "angular-star-rating": "^7.0.0",
    "css-star-rating": "^1.3.1",
    "install": "^0.13.0",
    "katex": "^0.16.8",
    "marked": "^15.0.12",
    "material-icons": "^1.13.14",
    "monaco-editor": "^0.49.0",
    "ngx-markdown": "^19.1.1",
    "npm": "^10.8.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^9.0.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.22",
    "@angular/cli": "~19.2.22",
    "@angular/compiler-cli": "^19.2.19",
    "@types/jasmine": "~4.3.0",
    "@types/marked": "^4.3.1",
    "@types/prismjs": "^1.26.0",
    "@types/uuid": "^9.0.2",
    "jasmine-core": "~4.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "lite-server": "^2.6.1",
    "prismjs": "^1.29.0",
    "typescript": "~5.8.3"
